{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/lookbook",
      "destination": "/brand-in-action",
      "permanent": true
    },
    {
      "source": "/lookbook/",
      "destination": "/brand-in-action",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/brand-in-action",
      "destination": "/lookbook.html"
    }
  ]
}
