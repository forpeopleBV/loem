{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/brand-story", "destination": "/index.html" },
    { "source": "/brand-story/", "destination": "/index.html" },
    { "source": "/brand-in-action", "destination": "/index.html" },
    { "source": "/brand-in-action/", "destination": "/index.html" },
    { "source": "/lookbook", "destination": "/index.html" },
    { "source": "/lookbook/", "destination": "/index.html" },
    { "source": "/brand-assets", "destination": "/index.html" },
    { "source": "/brand-assets/", "destination": "/index.html" },
    { "source": "/assets", "destination": "/index.html" },
    { "source": "/assets/", "destination": "/index.html" },
    { "source": "/assets-downloads", "destination": "/index.html" },
    { "source": "/assets-downloads/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ]
}
